{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/blackmath88/bridge-glass/bridgeboard/schema/bridgeboard-template.schema.json",
  "title": "Bridgeboard Template",
  "description": "A reusable Bridge Work facilitation canvas, stored as JSON. The single source of truth for a template lives here; both the board app and the Control Center read this format.",
  "type": "object",
  "required": ["id", "name", "category", "style", "version", "objects"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^t_[a-z0-9_]+$",
      "description": "Unique template id, e.g. t_flywheel"
    },
    "name": { "type": "string", "description": "Human-readable name" },
    "description": { "type": "string", "description": "What this template is for" },
    "category": {
      "type": "string",
      "enum": ["adoption", "governance", "m365", "leadership", "workshop", "risk", "custom"]
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "style": {
      "type": "string",
      "const": "bridgeboard_dark_glass",
      "description": "Locked. All templates render on the dark glass board."
    },
    "accent": {
      "type": "string",
      "default": "#2a8fa0",
      "description": "Bridgeboard tool accent (cyan). Used sparingly, on active/highlight elements only."
    },
    "objects": {
      "type": "array",
      "description": "Pre-positioned visual elements. Coordinates are normalized 0..1 so any screen renders identically.",
      "items": { "$ref": "#/definitions/object" }
    },
    "facilitation_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Private presenter notes. Visible only in host / control mode, never to clients."
    },
    "system_prompt": {
      "type": "string",
      "description": "Optional prompt used to generate or adapt this template."
    },
    "version": { "type": "string", "description": "Semver, e.g. 1.2.0" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },
  "definitions": {
    "object": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["text", "stroke", "line", "arrow", "rect", "circle"]
        },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "x1": { "type": "number" }, "y1": { "type": "number" },
        "x2": { "type": "number" }, "y2": { "type": "number" },
        "w": { "type": "number" }, "h": { "type": "number" },
        "text": { "type": "string" },
        "size": { "type": "number" },
        "color": {
          "type": "string",
          "description": "Use palette tokens only: cream #f0ebe3, teal #1a7a6d, cyan #2a8fa0, grey #8a8a8a, purple #3d1f47. Rose #d4416b for 'question hard' / warnings only."
        },
        "width": { "type": "number", "description": "Stroke width" }
      }
    }
  }
}
